rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Family documents — any authenticated user can read, only parent can write
    match /families/{familyId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Child profiles — open read/write for now (tighten later with device auth)
      match /profiles/{profileId} {
        allow read, write: if true;
      }

      // Notification outbox — any authenticated user can write; Cloud Function cleans up
      match /notifications/{notifId} {
        allow write: if request.auth != null;
      }
    }

    // Join code lookup — public read so kids can join without auth
    match /joinCodes/{code} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
